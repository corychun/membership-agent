APP_NAME=membership-agent
APP_ENV=dev
APP_PORT=8010
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/membership_agent
OPENAI_API_KEY=
ADMIN_REVIEW_EMAIL=ops@example.com
ADMIN_PASSWORD=123456
USDT_TRC20_ADDRESS=TDEMOUSDTTRC20ADDRESSREPLACEME

# 后台管理员系统
# 首次部署时，如果数据库 admin_users 表为空，会自动创建这个超级管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成强密码
# 用于签发后台登录 Token，生产环境必须设置为随机长字符串
ADMIN_TOKEN_SECRET=请改成至少32位随机字符串
